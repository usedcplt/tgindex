# Telegram API credentials
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_SESSION_NAME=tgindex_session
# For Render/cloud deployment, generate session string locally:
# python generate_session.py
TELEGRAM_SESSION_STRING=

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@host:port/dbname

# GitHub (optional - increases search results)
GITHUB_TOKEN=

# Application
APP_NAME=TGIndex
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# Crawler settings
CRAWL_BATCH_SIZE=100
CRAWL_MAX_CONCURRENT=5
CRAWL_REQUEST_TIMEOUT=30

# Rate limiting (safe max for userbots)
RATELIMIT_FLOOD_WAIT_THRESHOLD=300
RATELIMIT_MAX_REQUESTS_PER_SECOND=3

# Scheduler
SCHEDULER_DISCOVERY_INTERVAL_HOURS=1
SCHEDULER_VALIDATION_INTERVAL_MINUTES=5
SCHEDULER_METADATA_INTERVAL_MINUTES=5
SCHEDULER_UPDATE_INTERVAL_HOURS=6

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_REFRESH_SECONDS=30
