# Telegram API credentials
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_SESSION_NAME=tgindex_session

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@host:port/dbname

# Application
APP_NAME=TGIndex
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# Crawler settings
CRAWL_BATCH_SIZE=50
CRAWL_MAX_CONCURRENT=3
CRAWL_REQUEST_TIMEOUT=30

# Rate limiting
TELEGRAM_FLOOD_WAIT_THRESHOLD=300
TELEGRAM_MAX_REQUESTS_PER_SECOND=1

# Scheduler
DISCOVERY_INTERVAL_HOURS=1
VALIDATION_INTERVAL_MINUTES=5
METADATA_INTERVAL_MINUTES=5
UPDATE_INTERVAL_HOURS=6

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_REFRESH_SECONDS=30
